#!/usr/bin/env bash
set -euo pipefail

remote="$1"
branch=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0

# First push to a new branch — nothing to rebase against
if ! git ls-remote --exit-code "$remote" "refs/heads/$branch" &>/dev/null; then
    exit 0
fi

git fetch "$remote" "$branch"

# Already on top of remote — let git push proceed normally
if git merge-base --is-ancestor "$remote/$branch" HEAD; then
    exit 0
fi

# Remote has new commits: rebase, then ask the user to push again.
# Doing the push inside this hook causes git to use its pre-hook stale push
# plan (wrong expected remote SHA), so we rebase here and let the next
# 'git push' invocation start with a fresh, correct plan.
stashed=false
if [[ -n "$(git status --porcelain)" ]]; then
    git stash push --include-untracked -m "pre-push auto-stash"
    stashed=true
fi

if ! git rebase "$remote/$branch"; then
    if [[ "$stashed" == "true" ]]; then git stash pop --index; fi
    echo "pre-push: rebase failed — resolve conflicts then push again"
    exit 1
fi

if [[ "$stashed" == "true" ]]; then git stash pop --index; fi

echo "pre-push: rebased on $remote/$branch — run 'git push' again to send your commits"
exit 1
