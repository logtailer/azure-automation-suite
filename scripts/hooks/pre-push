#!/usr/bin/env bash
set -euo pipefail

remote="$1"
branch=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0

# Nothing to rebase on first push to a new branch
if ! git ls-remote --exit-code "$remote" "refs/heads/$branch" &>/dev/null; then
    exit 0
fi

# Stash any uncommitted changes so rebase can proceed cleanly
stashed=false
if [[ -n "$(git status --porcelain)" ]]; then
    git stash push --include-untracked -m "pre-push auto-stash"
    stashed=true
fi

restore_stash() {
    [[ "$stashed" == "true" ]] && git stash pop --index
}

# Loop: fetch → check → rebase until local HEAD is on top of remote.
# This handles the race where someone pushes between our rebase and the
# actual push attempt, which would otherwise cause a second rejection.
while true; do
    git fetch "$remote" "$branch"

    if git merge-base --is-ancestor "$remote/$branch" HEAD; then
        break  # remote is behind or at local HEAD — push will go through
    fi

    echo "pre-push: rebasing on $remote/$branch..."
    if ! git rebase "$remote/$branch"; then
        restore_stash
        echo "pre-push: rebase failed — resolve conflicts then push again"
        exit 1
    fi
done

restore_stash
